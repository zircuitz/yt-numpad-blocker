{
  "manifest_version": 3,
  "name": "YouTube Numpad Blocker",
  "version": "1.0.0",
  "description": "Stops accidental numpad presses from skipping to a random point in YouTube videos.",
  "icons": {
    "16": "logo-xs-no-bg.png",
    "32": "logo-xs-w-bg.png",
    "48": "logo-xs-w-bg.png",
    "128": "logo-unpadded.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Numpad Blocker"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
